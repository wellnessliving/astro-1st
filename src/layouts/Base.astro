---
import navItems from '../data/navigation.json';

interface NavItem {
  label: string;
  path: string;
  children?: NavItem[];
}

interface Props {
  title: string;
  bodyClass?: string;
  section?: string;
}
const { title, bodyClass = '', section = '' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentPath = Astro.url.pathname;

// Last nav item becomes CTA button
const menuItems = (navItems as NavItem[]).slice(0, -1);
const ctaItem = (navItems as NavItem[])[navItems.length - 1];

// Find current section for sidebar
function findSection(items: NavItem[], path: string): NavItem | null {
  for (const item of items) {
    if (item.children) {
      const parentPath = item.path.replace(/\//g, '');
      if (path.includes(parentPath)) return item;
    }
  }
  return null;
}
const currentSection = section
  ? (navItems as NavItem[]).find((i: NavItem) => i.path.replace(/\//g, '') === section.replace(/\//g, ''))
  : findSection(navItems as NavItem[], currentPath);
const hasSidebar = currentSection?.children && currentSection.children.length > 0;

function makeHref(itemPath: string): string {
  if (itemPath === '/') return base;
  return `${base}${itemPath.replace(/^\//, '')}`;
}

function isActive(itemPath: string): boolean {
  if (itemPath === '/') return currentPath === base;
  return currentPath.includes(itemPath.replace(/\//g, ''));
}

function isParentActive(item: NavItem): boolean {
  if (isActive(item.path)) return true;
  if (item.children) return item.children.some(c => isActive(c.path));
  return false;
}
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | WellnessLiving</title>
  <link rel="stylesheet" href={`${base}styles.css`} />
</head>
<body class={bodyClass}>
  <header class="site-header">
    <div class="container">
      <a href={`${base}`} class="site-logo">Wellness<span>Living</span></a>
      <nav class="site-nav" id="main-nav">
        {menuItems.map((item) => {
          if (item.children && item.children.length > 0) {
            return (
              <div class={`nav-dropdown ${isParentActive(item) ? 'active' : ''}`}>
                <a href={makeHref(item.path)} class={`nav-dropdown-trigger ${isParentActive(item) ? 'active' : ''}`}>
                  {item.label}
                  <svg class="dropdown-arrow" width="10" height="6" viewBox="0 0 10 6"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
                </a>
                <div class="nav-dropdown-menu">
                  {item.children.map((child) => (
                    <a href={makeHref(child.path)} class={isActive(child.path) ? 'active' : ''}>{child.label}</a>
                  ))}
                </div>
              </div>
            );
          }
          return <a href={makeHref(item.path)} class={isActive(item.path) ? 'active' : ''}>{item.label}</a>;
        })}
        {ctaItem && (
          <a href={makeHref(ctaItem.path)} class="btn-cta">{ctaItem.label}</a>
        )}
      </nav>
      <button class="nav-toggle" id="nav-toggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  {hasSidebar ? (
    <div class="page-with-sidebar">
      <aside class="page-sidebar">
        <h4 class="sidebar-title">{currentSection!.label}</h4>
        <ul class="sidebar-nav">
          <li>
            <a href={makeHref(currentSection!.path)} class={currentPath === makeHref(currentSection!.path) ? 'active' : ''}>
              Overview
            </a>
          </li>
          {currentSection!.children!.map((child) => (
            <li>
              <a href={makeHref(child.path)} class={currentPath.endsWith(child.path.replace(/\/$/, '/')) || currentPath.endsWith(child.path.replace(/\/$/, '')) ? 'active' : ''}>
                {child.label}
              </a>
            </li>
          ))}
        </ul>
      </aside>
      <main class="page-main">
        <nav class="breadcrumbs">
          <a href={base}>Home</a>
          <span class="breadcrumb-sep">/</span>
          <a href={makeHref(currentSection!.path)}>{currentSection!.label}</a>
          {currentPath !== makeHref(currentSection!.path) && (
            <>
              <span class="breadcrumb-sep">/</span>
              <span class="breadcrumb-current">{title}</span>
            </>
          )}
        </nav>
        <slot />
      </main>
    </div>
  ) : (
    <slot />
  )}

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>WellnessLiving</h4>
          <p>Empowering wellness businesses with modern technology and AI-driven solutions.</p>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <ul>
            <li><a href={`${base}about/`}>About Us</a></li>
            <li><a href={`${base}blog/`}>Blog</a></li>
            <li><a href={`${base}contact/`}>Contact</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Solutions</h4>
          <ul>
            <li><a href={`${base}services/`}>Services</a></li>
            <li><a href={`${base}faq/`}>FAQ</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Connect</h4>
          <ul>
            <li><a href="#">Twitter</a></li>
            <li><a href="#">LinkedIn</a></li>
            <li><a href="#">GitHub</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        &copy; {new Date().getFullYear()} WellnessLiving. All rights reserved.
      </div>
    </div>
  </footer>

  <script is:inline>
    document.getElementById('nav-toggle')?.addEventListener('click', () => {
      document.getElementById('main-nav')?.classList.toggle('open');
    });
  </script>
</body>
</html>
