---
import navItems from '../data/navigation.json';

interface Props {
  title: string;
  bodyClass?: string;
}
const { title, bodyClass = '' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentPath = Astro.url.pathname;

// Last nav item becomes CTA button
const menuItems = navItems.slice(0, -1);
const ctaItem = navItems[navItems.length - 1];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | WellnessLiving</title>
  <link rel="stylesheet" href={`${base}styles.css`} />
</head>
<body class={bodyClass}>
  <header class="site-header">
    <div class="container">
      <a href={`${base}`} class="site-logo">Wellness<span>Living</span></a>
      <nav class="site-nav" id="main-nav">
        {menuItems.map((item) => {
          const href = item.path === '/' ? base : `${base}${item.path.replace(/^\//, '')}`;
          const isActive = item.path === '/'
            ? currentPath === base
            : currentPath.includes(item.path.replace(/\//g, ''));
          return <a href={href} class={isActive ? 'active' : ''}>{item.label}</a>;
        })}
        {ctaItem && (
          <a href={`${base}${ctaItem.path.replace(/^\//, '')}`} class="btn-cta">{ctaItem.label}</a>
        )}
      </nav>
      <button class="nav-toggle" id="nav-toggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <slot />

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>WellnessLiving</h4>
          <p>Empowering wellness businesses with modern technology and AI-driven solutions.</p>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <ul>
            <li><a href={`${base}about/`}>About Us</a></li>
            <li><a href={`${base}blog/`}>Blog</a></li>
            <li><a href={`${base}contact/`}>Contact</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Solutions</h4>
          <ul>
            <li><a href={`${base}services/`}>Services</a></li>
            <li><a href={`${base}faq/`}>FAQ</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Connect</h4>
          <ul>
            <li><a href="#">Twitter</a></li>
            <li><a href="#">LinkedIn</a></li>
            <li><a href="#">GitHub</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        &copy; {new Date().getFullYear()} WellnessLiving. All rights reserved.
      </div>
    </div>
  </footer>

  <script is:inline>
    document.getElementById('nav-toggle')?.addEventListener('click', () => {
      document.getElementById('main-nav')?.classList.toggle('open');
    });
  </script>
</body>
</html>
