---
interface Props {
  title: string;
  bodyClass?: string;
}
const { title, bodyClass = '' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | WellnessLiving</title>
  <link rel="stylesheet" href={`${base}styles.css`} />
</head>
<body class={bodyClass}>
  <header class="site-header">
    <div class="container">
      <a href={`${base}`} class="site-logo">Wellness<span>Living</span></a>
      <nav class="site-nav" id="main-nav">
        <a href={`${base}`} class={currentPath === `${base}` ? 'active' : ''}>Home</a>
        <a href={`${base}about/`} class={currentPath.includes('about') ? 'active' : ''}>About</a>
        <a href={`${base}blog/`} class={currentPath.includes('blog') ? 'active' : ''}>Blog</a>
        <a href={`${base}#contact`} class="btn-cta">Contact Us</a>
      </nav>
      <button class="nav-toggle" id="nav-toggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <slot />

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>WellnessLiving</h4>
          <p>Empowering wellness businesses with modern technology and AI-driven solutions.</p>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <ul>
            <li><a href={`${base}about/`}>About Us</a></li>
            <li><a href={`${base}blog/`}>Blog</a></li>
            <li><a href="#">Careers</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Solutions</h4>
          <ul>
            <li><a href="#">Scheduling</a></li>
            <li><a href="#">Payments</a></li>
            <li><a href="#">Analytics</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Connect</h4>
          <ul>
            <li><a href="#">Twitter</a></li>
            <li><a href="#">LinkedIn</a></li>
            <li><a href="#">GitHub</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        &copy; {new Date().getFullYear()} WellnessLiving. All rights reserved.
      </div>
    </div>
  </footer>

  <script is:inline>
    document.getElementById('nav-toggle')?.addEventListener('click', () => {
      document.getElementById('main-nav')?.classList.toggle('open');
    });
  </script>
</body>
</html>
