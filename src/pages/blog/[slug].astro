---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

// Динамический роутинг: генерируем страницу для каждого .md файла
export async function getStaticPaths() {
  const posts = Object.values(
    import.meta.glob('../../content/blog/*.md', { eager: true })
  ) as any[];

  return posts.map((post) => ({
    params: { slug: post.frontmatter.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = post;
---
<Base title={post.frontmatter.title}>
  <article>
    <time style="color: #888; font-size: 0.85rem;">{post.frontmatter.date}</time>
    <h1 style="margin-top: 0.25rem;">{post.frontmatter.title}</h1>
    <div style="margin-top: 1.5rem; line-height: 1.8;">
      <Content />
    </div>
    <div style="margin-top: 2rem;">
      <a href={`${base}blog`} style="color: #2563eb;">&larr; Back to blog</a>
    </div>
  </article>
</Base>
