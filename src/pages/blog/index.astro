---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const modules = import.meta.glob('../../content/blog/*.md', { eager: true });
const posts = Object.entries(modules).map(([filepath, post]: [string, any]) => ({
  ...post,
  slug: post.frontmatter.slug || filepath.split('/').pop()?.replace('.md', ''),
}));
posts.sort((a, b) => new Date(b.frontmatter.date || b.frontmatter.pubDate || 0).getTime() - new Date(a.frontmatter.date || a.frontmatter.pubDate || 0).getTime());

const categories = ['All', 'Technology', 'Business', 'Wellness'];
const recentPosts = posts.slice(0, 5);
---
<Base title="Blog">
  <!-- Page Header -->
  <div class="blog-page-header">
    <div class="container">
      <h1>Blog</h1>
      <p>Insights, tips, and updates for wellness business owners</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="blog-layout">
        <!-- Main Content -->
        <div class="blog-main">
          {posts.map((post, i) => (
            <article class={`wp-post-card ${i === 0 ? 'wp-post-featured' : ''}`}>
              <div class="wp-post-thumb">
                <a href={`${base}blog/${post.slug}/`}>
                  <div class="wp-post-thumb-placeholder">
                    <span>{post.frontmatter.title?.charAt(0) || 'W'}</span>
                  </div>
                </a>
              </div>
              <div class="wp-post-content">
                <div class="wp-post-meta">
                  <span class="wp-post-category">{post.frontmatter.category || 'General'}</span>
                  <span class="wp-post-date">{post.frontmatter.date || post.frontmatter.pubDate}</span>
                  <span class="wp-post-author">by {post.frontmatter.author || 'Admin'}</span>
                </div>
                <h2 class="wp-post-title">
                  <a href={`${base}blog/${post.slug}/`}>{post.frontmatter.title}</a>
                </h2>
                <p class="wp-post-excerpt">{post.frontmatter.description}</p>
                <div class="wp-post-footer">
                  <a href={`${base}blog/${post.slug}/`} class="wp-read-more">Continue Reading &rarr;</a>
                </div>
              </div>
            </article>
          ))}
        </div>

        <!-- Sidebar -->
        <aside class="blog-sidebar">
          <!-- Search -->
          <div class="sidebar-widget">
            <h3 class="widget-title">Search</h3>
            <div class="search-box">
              <input type="text" placeholder="Search posts..." class="search-input" />
            </div>
          </div>

          <!-- Categories -->
          <div class="sidebar-widget">
            <h3 class="widget-title">Categories</h3>
            <ul class="widget-list">
              {categories.map((cat) => (
                <li>
                  <a href="#">{cat}</a>
                  <span class="widget-count">{cat === 'All' ? posts.length : Math.floor(Math.random() * 3 + 1)}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Recent Posts -->
          <div class="sidebar-widget">
            <h3 class="widget-title">Recent Posts</h3>
            <ul class="recent-posts">
              {recentPosts.map((post) => (
                <li>
                  <a href={`${base}blog/${post.slug}/`}>
                    <span class="rp-title">{post.frontmatter.title}</span>
                    <span class="rp-date">{post.frontmatter.date || post.frontmatter.pubDate}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Tags -->
          <div class="sidebar-widget">
            <h3 class="widget-title">Tags</h3>
            <div class="tag-cloud">
              <a href="#" class="tag">AI</a>
              <a href="#" class="tag">Wellness</a>
              <a href="#" class="tag">Fitness</a>
              <a href="#" class="tag">Technology</a>
              <a href="#" class="tag">Business</a>
              <a href="#" class="tag">Marketing</a>
              <a href="#" class="tag">Astro</a>
              <a href="#" class="tag">GitHub</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Blog Page Header */
  .blog-page-header {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    color: #fff;
    padding: 60px 0;
    text-align: center;
  }
  .blog-page-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 8px;
  }
  .blog-page-header p {
    opacity: 0.8;
    font-size: 1.1rem;
  }

  /* Blog Layout: Main + Sidebar */
  .blog-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 48px;
    align-items: start;
  }

  /* Post Cards */
  .wp-post-card {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 24px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 28px;
    background: #fff;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .wp-post-card:hover {
    box-shadow: 0 4px 24px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }
  .wp-post-featured {
    grid-template-columns: 1fr;
  }
  .wp-post-featured .wp-post-thumb-placeholder {
    height: 240px;
  }

  .wp-post-thumb-placeholder {
    width: 100%;
    height: 100%;
    min-height: 180px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .wp-post-thumb-placeholder span {
    font-size: 3rem;
    font-weight: 800;
    color: rgba(255,255,255,0.3);
  }

  .wp-post-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .wp-post-featured .wp-post-content {
    padding: 0 24px 24px;
  }

  .wp-post-meta {
    display: flex;
    gap: 16px;
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 8px;
    flex-wrap: wrap;
    align-items: center;
  }
  .wp-post-category {
    background: #2563eb;
    color: #fff;
    padding: 2px 10px;
    border-radius: 3px;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .wp-post-title {
    font-size: 1.3rem;
    margin-bottom: 10px;
    line-height: 1.4;
  }
  .wp-post-featured .wp-post-title {
    font-size: 1.6rem;
  }
  .wp-post-title a {
    color: #1a1a2e;
    text-decoration: none;
  }
  .wp-post-title a:hover {
    color: #2563eb;
  }

  .wp-post-excerpt {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 14px;
  }

  .wp-read-more {
    font-weight: 600;
    font-size: 0.9rem;
    color: #2563eb;
  }
  .wp-read-more:hover {
    color: #1d4ed8;
  }

  /* Sidebar */
  .blog-sidebar {
    position: sticky;
    top: 96px;
  }

  .sidebar-widget {
    background: #f8f9fa;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 24px;
  }
  .widget-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid #2563eb;
    color: #1a1a2e;
  }

  .search-input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .search-input:focus {
    border-color: #2563eb;
  }

  .widget-list {
    list-style: none;
  }
  .widget-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid #e5e7eb;
  }
  .widget-list li:last-child {
    border-bottom: none;
  }
  .widget-list a {
    color: #333;
    font-size: 0.9rem;
  }
  .widget-list a:hover {
    color: #2563eb;
  }
  .widget-count {
    background: #e5e7eb;
    color: #555;
    font-size: 0.8rem;
    padding: 2px 8px;
    border-radius: 10px;
  }

  .recent-posts {
    list-style: none;
  }
  .recent-posts li {
    border-bottom: 1px solid #e5e7eb;
    padding: 10px 0;
  }
  .recent-posts li:last-child {
    border-bottom: none;
  }
  .recent-posts a {
    text-decoration: none;
    display: block;
  }
  .rp-title {
    display: block;
    color: #333;
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.4;
    margin-bottom: 2px;
  }
  .recent-posts a:hover .rp-title {
    color: #2563eb;
  }
  .rp-date {
    font-size: 0.8rem;
    color: #999;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag {
    display: inline-block;
    padding: 4px 12px;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 0.8rem;
    color: #555;
    transition: all 0.2s;
  }
  .tag:hover {
    background: #2563eb;
    color: #fff;
    border-color: #2563eb;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .blog-layout {
      grid-template-columns: 1fr;
    }
    .blog-sidebar {
      position: static;
    }
    .wp-post-card {
      grid-template-columns: 1fr;
    }
    .wp-post-thumb-placeholder {
      min-height: 160px;
    }
  }
</style>
