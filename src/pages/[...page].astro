---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

export async function getStaticPaths() {
  // Nested pages: src/content/pages/**/*.md → /pricing/starter/, /services/scheduling/, etc.
  const nestedModules = import.meta.glob('../content/pages/**/*.md', { eager: true });

  const paths: any[] = [];
  const seen = new Set<string>();

  for (const [filepath, page] of Object.entries(nestedModules) as [string, any][]) {
    // Extract relative path from content/pages/
    const rel = filepath.replace('../content/pages/', '').replace('.md', '');
    const slug = (page.frontmatter?.slug || rel);
    const segments = slug.split('/');

    const key = segments.join('/');
    if (seen.has(key)) continue;
    seen.add(key);

    paths.push({ params: { page: segments.join('/') }, props: { page } });
  }

  return paths;
}

const { page } = Astro.props;
const { Content } = page;
---
<Base title={page.frontmatter.title}>
  <div class="post-header">
    <div class="container">
      <h1>{page.frontmatter.title}</h1>
      {page.frontmatter.description && <p style="opacity:0.8; font-size:1.1rem; margin-top:8px;">{page.frontmatter.description}</p>}
    </div>
  </div>
  <div class="post-content">
    <Content />
  </div>
</Base>
