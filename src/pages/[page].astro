---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

export async function getStaticPaths() {
  const modules = import.meta.glob('../content/pages/*.md', { eager: true });
  return Object.entries(modules).map(([filepath, page]: [string, any]) => {
    const slug = filepath.split('/').pop()?.replace('.md', '');
    return { params: { page: slug }, props: { page } };
  });
}

const { page } = Astro.props;
const { Content } = page;
---
<Base title={page.frontmatter.title}>
  <div class="post-header">
    <div class="container">
      <h1>{page.frontmatter.title}</h1>
      {page.frontmatter.description && <p style="opacity:0.8; font-size:1.1rem; margin-top:8px;">{page.frontmatter.description}</p>}
    </div>
  </div>
  <div class="post-content">
    <Content />
  </div>
</Base>
